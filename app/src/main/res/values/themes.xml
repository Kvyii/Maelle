<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Applied to the app once the splash is dismissed. -->
    <style name="Theme.Maelle" parent="android:Theme.Material.NoActionBar" />

    <!-- The launch theme: shows the fencing icon on the brand background, then
         hands off to Theme.Maelle. This is the app's declared theme so the
         splash appears on cold start. -->
    <style name="Theme.Maelle.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/splash_background</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/splash_icon</item>
        <item name="postSplashScreenTheme">@style/Theme.Maelle</item>
    </style>
</resources>
